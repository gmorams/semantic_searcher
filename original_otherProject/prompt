Paso 4: Implementación Técnica
Opción A: Grafo RDF con SPARQL

python
from rdflib import Graph, Namespace, URIRef, Literal
from rdflib.namespace import RDF, RDFS

g = Graph()
FIB = Namespace("http://fib.upc.edu/ontology#")

# Añadir asignatura
asig_uri = URIRef(FIB["Algoritmia"])
g.add((asig_uri, RDF.type, FIB.Asignatura))
g.add((asig_uri, FIB.creditos, Literal(7.5)))

# Consulta SPARQL
query = """
SELECT ?asignatura ?profesor
WHERE {
    ?asignatura rdf:type fib:Asignatura .
    ?profesor fib:imparte ?asignatura .
    ?asignatura fib:creditos ?creditos .
    FILTER (?creditos > 6)
}
"""
results = g.query(query)
